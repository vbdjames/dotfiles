# ~/.ssh/config
# SSH client configuration.
# Private keys are stored in ~/.ssh/ and backed up in 1Password.
# They are NOT tracked in this repo.

# Reuse connections for speed
Host *
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

Host *
  IdentityAgent ~/.1password/agent.sock

# Add host-specific config below

# GitHub
Host github.com
    User git
    IdentityFile ~/.ssh/id_rsa.pub
    IdentitiesOnly yes

